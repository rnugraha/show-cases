{
	"compilerOptions": {
		"baseUrl": ".",
		"target": "es6",
		"jsx": "react-jsx",
		"lib": ["dom", "es2019", "dom.iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "**/*.spec.ts"]
}
